---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const updated = 'July 2025';
---

<BaseLayout
  title="Terms & Conditions — Ambika Biotech / RHA India"
  description="Terms & Conditions for using rhaindia.com and for enquiries and orders placed with Ambika Ricemill & Ambika Biotech (RHA India)."
  path="/terms/"
>
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container crumb-inner">
      <a href="/">Home</a><span>/</span><span class="crumb-current">Terms</span>
    </div>
  </nav>

  <section class="legal">
    <div class="container legal-wrap" data-reveal>
      <div class="eyebrow">Legal</div>
      <h1 class="legal-h1">Terms &amp; Conditions</h1>
      <p class="legal-updated">Last updated: {updated}</p>

      <p>These Terms &amp; Conditions govern your use of the website
        <strong>{site.url.replace('https://', '')}</strong> and any enquiry or order placed with
        <strong>{site.legalName}</strong> (operating under the brand <strong>{site.brand}</strong>,
        GSTIN {site.gstin}), {site.address.full}. By using this website or contacting us, you agree
        to these terms.</p>

      <h2>Products &amp; specifications</h2>
      <p>All product specifications, silica content, calorific values and other figures shown on this
        website are indicative and provided for general guidance. Confirmed, NABL-tested lab values
        for a specific consignment are available on request and form the basis of any supply. Colours
        and images are representative and may vary from actual material.</p>

      <h2>Quotations &amp; orders</h2>
      <p>Quotations are valid for the period stated and are subject to confirmation of stock, grade,
        quantity, destination and prevailing prices at the time of order. An order is binding only
        once accepted by us in writing. Minimum order quantities, packing and lead times vary by
        product and destination.</p>

      <h2>Pricing, payment &amp; export</h2>
      <p>Prices, taxes, duties, freight and applicable Incoterms are as agreed in the specific
        quotation or contract. For export orders, documentation and shipping are handled as mutually
        agreed. The buyer is responsible for ensuring the product is permitted for import and use in
        the destination country.</p>

      <h2>Intellectual property</h2>
      <p>All content on this website — including text, logos, images and design — is owned by or
        licensed to {site.legalName} and may not be copied or reused without prior written
        permission.</p>

      <h2>Limitation of liability</h2>
      <p>The website and its content are provided &ldquo;as is&rdquo; without warranties of any kind.
        To the extent permitted by law, we are not liable for any indirect or consequential loss
        arising from use of the website. Nothing in these terms limits liability that cannot be
        excluded under applicable law.</p>

      <h2>Governing law</h2>
      <p>These terms are governed by the laws of India, and any disputes are subject to the
        jurisdiction of the courts of {site.address.region}, India.</p>

      <h2>Contact us</h2>
      <p>
        {site.legalName} ({site.brand})<br />
        {site.address.full}<br />
        Email: <a href={`mailto:${site.email}`}>{site.email}</a><br />
        Phone: <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a><br />
        GSTIN: {site.gstin}
      </p>

      <p class="legal-note">These Terms &amp; Conditions are provided for general information and may
        be updated from time to time. Please review them periodically for changes.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb { border-bottom: 1px solid #efe9d9; background: var(--cream); }
  .crumb-inner { display: flex; align-items: center; gap: 10px; padding: 14px 32px; font-size: 13.5px; color: var(--text-faint); }
  .crumb-inner a { color: var(--text-faint); text-decoration: none; }
  .crumb-inner a:hover { color: var(--green-800); }
  .crumb-inner span { opacity: 0.5; }
  .crumb-current { color: var(--green-800) !important; font-weight: 600; opacity: 1 !important; }

  .legal { padding: 40px 0 56px; }
  .legal-wrap { max-width: 820px; }
  .legal-h1 { font-family: var(--font-head); font-weight: 800; font-size: 36px; line-height: 1.08; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 10px; }
  .legal-updated { font-family: var(--font-mono); font-size: 13px; color: var(--text-faint); margin-bottom: 28px; }
  .legal-wrap p { font-size: 16px; line-height: 1.7; color: var(--text-soft); margin-bottom: 18px; }
  .legal-wrap h2 { font-family: var(--font-head); font-weight: 700; font-size: 22px; color: var(--ink); margin: 34px 0 12px; }
  .legal-wrap a { color: var(--green-700); text-decoration: underline; font-weight: 600; }
  .legal-wrap a:hover { color: var(--gold-700); }
  .legal-note { font-size: 14px !important; color: var(--text-faint) !important; margin-top: 26px; }
  @media (max-width: 640px) { .legal-h1 { font-size: 31px; } }
</style>
