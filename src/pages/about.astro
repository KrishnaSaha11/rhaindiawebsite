---
import BaseLayout from '../layouts/BaseLayout.astro';
import RotatingSpotlight from '../components/RotatingSpotlight.astro';
import { site, trustStrip } from '../config/site';
import { products } from '../data/products';

const aboutSpotlight = [
  {
    eyebrow: 'About Ambika Biotech',
    title: 'Two decades of turning rice husk into industrial-grade silica',
    desc: 'Ambika Ricemill & Ambika Biotech — operating under the brand RHA India — manufactures and exports high-silica Rice Husk Ash and rice husk products from Sambalpur, Odisha. Our NABL-tested material is trusted by steel plants, refractory makers, concrete producers and biomass energy users across India and abroad.',
    href: '/products/',
    linkText: 'Our Products',
    img: '/images/sections/rice-mill-plant.webp',
    alt: 'Rice husk at the Ambika Biotech rice mill in Sambalpur, Odisha — feedstock for high-silica Rice Husk Ash',
  },
  ...products.map((p) => ({
    eyebrow: p.categoryLabel,
    title: p.name,
    desc: p.value,
    href: `/${p.slug}/`,
    linkText: 'View Product',
    img: p.images?.[0]?.src ?? `/images/products/${p.slug}.svg`,
    alt: p.images?.[0]?.alt ?? p.heroAlt,
  })),
];

const values = [
  { num: '01', title: 'Consistency first', body: 'A uniform, certified spec delivered batch after batch — the foundation of every long-term supply relationship.' },
  { num: '02', title: 'Independent testing', body: 'NABL-tested material with documented parameters, so buyers receive verifiable quality, not claims.' },
  { num: '03', title: 'Reliable bulk supply', body: 'Steady volumes and dependable lead times for high-throughput industrial procurement.' },
  { num: '04', title: 'Export-ready', body: 'Full documentation and logistics handled for smooth shipping to partners worldwide.' },
];

const milestones = [
  { year: '20+ yrs', text: 'Manufacturing and exporting rice husk products from Sambalpur, Odisha.' },
  { year: 'NABL', text: 'Independent lab testing across every grade we produce.' },
  { year: 'Global', text: 'Exporting to partners in Belgium, Germany and the Middle East.' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: site.url + '/about/' },
  ],
};
---

<BaseLayout
  title="About Ambika Biotech — Rice Husk Ash Manufacturer in Odisha, India"
  description="For over 20 years Ambika Ricemill & Ambika Biotech (RHA India) has manufactured and exported high-silica Rice Husk Ash and rice husk products from Sambalpur, Odisha. NABL tested, export ready."
  path="/about/"
  jsonLd={[breadcrumb]}
>
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container crumb-inner">
      <a href="/">Home</a><span>/</span><span class="crumb-current">About</span>
    </div>
  </nav>

  <section class="a-hero">
    <div class="container" data-reveal>
      <RotatingSpotlight items={aboutSpotlight} titleTag="h1" mediaSide="right" interval={3000} eager={true}>
        <div class="a-cta">
          <a href="/contact/#quote-form" class="btn btn-primary">Get a Quote <span class="mono">→</span></a>
          <a href="/products/" class="btn btn-outline">View Products</a>
        </div>
      </RotatingSpotlight>
    </div>
  </section>

  <section class="trust-strip">
    <div class="container">
      <div class="trust-grid" data-reveal>
        {trustStrip.map((t) => (
          <div class="trust-item">
            <div class="trust-big">{t.big}</div>
            <div class="trust-label">{t.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container a-story-grid">
      <div data-reveal>
        <div class="eyebrow">Our Story</div>
        <h2 class="a-h2">From a rice mill to a trusted RHA exporter</h2>
      </div>
      <div data-reveal>
        <p class="body-p">What began as a rice milling operation in Sambalpur grew into a specialist manufacturer of Rice Husk Ash and rice husk products. We recognised early that the husk left over from milling — too often burned as waste — was in fact a valuable source of high-purity amorphous silica and clean biomass energy.</p>
        <p class="body-p">Today we process rice husk into six grades: micronized RHA ground powder, steel-grade granules and pellets, raw husk, rice husk powder and biomass fuel pellets. Each is produced to a consistent specification, independently NABL-tested, and backed by reliable bulk capacity and full export documentation.</p>
        <p class="body-p">Our customers are procurement and technical teams who need certainty: a material that performs the same way every delivery, with paperwork that stands up to scrutiny at home and at the port.</p>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="sec-head center" data-reveal>
        <div class="eyebrow">What We Stand For</div>
        <h2 class="a-h2">The principles behind every batch</h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card" data-reveal>
            <div class="value-num">{v.num}</div>
            <h3 class="value-title">{v.title}</h3>
            <p class="value-body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">At a Glance</div>
        <h2 class="a-h2">Why partners rely on us</h2>
      </div>
      <div class="mile-grid">
        {milestones.map((m) => (
          <div class="mile-card" data-reveal>
            <div class="mile-year">{m.year}</div>
            <p class="mile-text">{m.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="band-wrap">
    <div class="container" data-reveal>
      <div class="cta-band">
        <div class="cb-text">
          <h2 class="cb-h2">Let's build a reliable supply relationship</h2>
          <p class="cb-p">Tell us your spec and volume — we reply within one business day with pricing, lead time and documentation.</p>
        </div>
        <a href="/contact/#quote-form" class="btn btn-gold">Get a Quote <span class="mono">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb { border-bottom: 1px solid #efe9d9; background: var(--cream); }
  .crumb-inner { display: flex; align-items: center; gap: 10px; padding: 14px 32px; font-size: 13.5px; color: var(--text-faint); }
  .crumb-inner a { color: var(--text-faint); text-decoration: none; }
  .crumb-inner span { opacity: 0.5; }
  .crumb-current { color: var(--green-800) !important; font-weight: 600; opacity: 1 !important; }

  .a-hero { padding: 64px 0 80px; background: radial-gradient(110% 80% at 88% 0%, #eef3ea 0%, var(--cream) 55%); }
  .a-hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; }
  .a-h1 { font-family: var(--font-head); font-weight: 800; font-size: 46px; line-height: 1.08; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 20px; }
  .a-lead { font-size: 18px; line-height: 1.65; color: var(--text-soft); margin-bottom: 28px; }
  .a-cta { display: flex; gap: 14px; flex-wrap: wrap; }
  .a-img { width: 100%; aspect-ratio: 4/3; border-radius: 20px; overflow: hidden; background: var(--cream-2); }

  .trust-strip { background: var(--green-800); }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .trust-item { padding: 30px 26px; border-right: 1px solid rgba(255,255,255,0.2); display: flex; flex-direction: column; gap: 7px; }
  .trust-item:last-child { border-right: none; }
  .trust-big { font-family: var(--font-head); font-weight: 800; font-size: 44px; color: var(--gold); line-height: 1; }
  .trust-label { font-size: 14.5px; color: #cbd6c7; line-height: 1.35; }

  .section-white { background: #fff; border-top: 1px solid #efe9d9; border-bottom: 1px solid #efe9d9; }
  .a-h2 { font-family: var(--font-head); font-weight: 800; font-size: 34px; line-height: 1.12; color: var(--ink); }
  .a-story-grid { display: grid; grid-template-columns: 0.42fr 0.58fr; gap: 60px; align-items: start; }
  .body-p { font-size: 17px; line-height: 1.7; color: var(--text-soft); margin-bottom: 18px; }
  .sec-head { margin-bottom: 44px; max-width: 640px; }
  .sec-head.center { margin-left: auto; margin-right: auto; text-align: center; }

  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .value-card { background: var(--cream); border: 1px solid var(--line); border-radius: 16px; padding: 28px 24px; }
  .value-num { width: 44px; height: 44px; border-radius: 12px; background: var(--tile); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-weight: 800; font-size: 16px; color: var(--green-600); margin-bottom: 16px; }
  .value-title { font-family: var(--font-head); font-weight: 700; font-size: 18px; color: var(--ink); margin-bottom: 8px; }
  .value-body { font-size: 14px; line-height: 1.55; color: var(--text-muted); }

  .mile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .mile-card { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 32px 28px; }
  .mile-year { font-family: var(--font-head); font-weight: 800; font-size: 30px; color: var(--green-600); margin-bottom: 12px; }
  .mile-text { font-size: 15px; line-height: 1.6; color: var(--text-muted); }

  .band-wrap { padding-bottom: var(--section-y); }
  .cta-band { position: relative; overflow: hidden; background: var(--green-800); border-radius: 24px; padding: 56px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cb-h2 { font-family: var(--font-head); font-weight: 800; font-size: 32px; line-height: 1.14; color: var(--cream); margin-bottom: 12px; max-width: 620px; }
  .cb-p { font-size: 16.5px; color: #bfcbba; max-width: 540px; }

  @media (max-width: 1024px) { .a-h1 { font-size: 38px; } .a-h2 { font-size: 28px; } .values-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 860px) { .a-hero-grid, .a-story-grid { grid-template-columns: 1fr; gap: 40px; } .trust-grid { grid-template-columns: repeat(2, 1fr); } .trust-item:nth-child(2) { border-right: none; } }
  @media (max-width: 640px) { .a-h1 { font-size: 30px; } .values-grid, .mile-grid { grid-template-columns: 1fr; } .cta-band { padding: 34px 24px; } .a-cta .btn, .cta-band .btn { width: 100%; justify-content: center; } }

  /* ---- Desktop density (≥1024px only) ---- */
  @media (min-width: 1024px) {
    .a-hero { padding: 44px 0 56px; }
    .a-h2 { font-size: 30px; }
    .a-story-grid { gap: 48px; }
    .sec-head { margin-bottom: 32px; }
    .values-grid { gap: 18px; }
    .mile-grid { gap: 18px; }
    .cta-band { padding: 44px; }
    .cb-h2 { font-size: 28px; }
  }
</style>
