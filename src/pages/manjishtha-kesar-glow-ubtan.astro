<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manjishtha Kesar Glow Ubtan — Ingredients & Benefits</title>
<style is:inline>
  :root{
    --emerald:#1c3525; --emerald2:#264a32; --gold:#b3914f; --gold-l:#cdb079;
    --ivory:#faf6ec; --ivory2:#f3ecd8; --ink:#2a3327; --muted:#6a7259;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:-apple-system,"Helvetica Neue",Helvetica,Arial,sans-serif;color:var(--ink);background:var(--ivory);line-height:1.6;}
  .serif{font-family:Georgia,"Times New Roman",serif;}
  .wrap{max-width:1080px;margin:0 auto;padding:0 22px;}
  .kick{font-size:.72rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);font-weight:600;}

  /* HERO */
  header{background:linear-gradient(160deg,#1c3525,#2f4a30 60%,#3a5a38);color:#f3ecd8;padding:54px 0 60px;}
  .hero{display:flex;align-items:center;gap:48px;flex-wrap:wrap;}
  .hero-txt{flex:1;min-width:280px;}
  .hero .kick{color:var(--gold-l);}
  .hero h1{font-size:2.9rem;line-height:1.08;margin:14px 0 12px;color:#f5efdc;font-weight:700;}
  .hero h1 em{color:var(--gold-l);font-style:italic;}
  .hero p{color:#cfc6ac;font-size:1.02rem;max-width:440px;}
  .hero .badges{margin-top:22px;display:flex;gap:10px;flex-wrap:wrap;}
  .hero .badges span{border:1px solid rgba(205,176,121,.5);color:var(--gold-l);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;padding:6px 12px;border-radius:20px;}

  /* PROTOTYPE JAR MOCKUP */
  .mock{flex:0 0 250px;display:flex;justify-content:center;}
  .proto-tag{position:absolute;margin-top:-14px;margin-left:120px;background:var(--gold);color:#1c3525;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700;padding:3px 10px;border-radius:12px;transform:rotate(6deg);}
  .jar{width:200px;filter:drop-shadow(0 22px 30px rgba(0,0,0,.35));}
  .jar .lid{height:46px;width:78%;margin:0 auto;
    background:linear-gradient(180deg,#e3c886,#cdb079 45%,#a98e54);
    border-radius:14px 14px 6px 6px;position:relative;box-shadow:inset 0 -4px 6px rgba(0,0,0,.25),inset 0 3px 4px rgba(255,255,255,.5);}
  .jar .lid::after{content:"";position:absolute;left:8%;right:8%;top:38%;height:3px;background:rgba(0,0,0,.12);border-radius:2px;}
  .jar .glass{margin-top:4px;height:230px;border-radius:10px 10px 22px 22px;position:relative;overflow:hidden;
    background:linear-gradient(100deg,rgba(255,255,255,.55),rgba(255,255,255,.15) 30%,rgba(255,255,255,.35) 55%,rgba(255,255,255,.1));
    border:1.5px solid rgba(255,255,255,.5);box-shadow:inset 0 0 22px rgba(255,255,255,.25);}
  /* the herbal powder inside */
  .jar .powder{position:absolute;left:5px;right:5px;bottom:5px;height:64%;border-radius:6px 6px 18px 18px;
    background:linear-gradient(180deg,#9c5a3c,#7e4329 60%,#5e3018);
    box-shadow:inset 0 6px 10px rgba(0,0,0,.25);}
  .jar .powder::before{content:"";position:absolute;top:0;left:0;right:0;height:10px;border-radius:6px 6px 0 0;
    background:repeating-linear-gradient(90deg,#a8623f,#a8623f 3px,#925334 3px,#925334 6px);opacity:.7;}
  .jar .shine{position:absolute;top:8px;left:14px;width:26px;height:78%;border-radius:40%;
    background:linear-gradient(180deg,rgba(255,255,255,.75),rgba(255,255,255,0));filter:blur(2px);}
  /* label */
  .jar .label{position:absolute;left:50%;top:30%;transform:translateX(-50%);width:74%;
    background:rgba(250,246,236,.95);border:1px solid #e6dcc4;border-radius:6px;padding:10px 6px;text-align:center;z-index:3;box-shadow:0 3px 8px rgba(0,0,0,.12);}
  .jar .label .lh{font-size:.42rem;letter-spacing:.18em;color:var(--gold);text-transform:uppercase;}
  .jar .label .ln{font-family:Georgia,serif;font-size:.62rem;color:var(--emerald);font-weight:700;line-height:1.2;margin:3px 2px;}
  .jar .label .lr{width:32px;height:1px;background:var(--gold);margin:4px auto;}
  .jar .label .ls{font-size:.36rem;letter-spacing:.14em;color:var(--gold);text-transform:uppercase;}

  /* SECTIONS */
  section{padding:54px 0;}
  .sec-head{text-align:center;margin-bottom:34px;}
  .sec-head h2{font-size:2rem;color:var(--emerald);margin-top:6px;}
  .sec-head .rule{width:46px;height:2px;background:var(--gold);margin:12px auto 0;}
  .lead{max-width:680px;margin:0 auto;text-align:center;color:var(--muted);font-size:1.05rem;}

  .intro{background:var(--ivory2);}

  /* ingredient grid */
  .ing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
  .ing-card{background:#fff;border:1px solid #ece2cc;border-radius:14px;padding:22px 20px;transition:transform .2s,box-shadow .2s;}
  .ing-card:hover{transform:translateY(-4px);box-shadow:0 14px 28px rgba(28,53,37,.12);}
  .ing-card .ic{font-size:1.9rem;}
  .ing-card .star{float:right;color:var(--gold);font-size:.7rem;letter-spacing:.1em;border:1px solid var(--gold);border-radius:10px;padding:2px 7px;}
  .ing-card h3{font-family:Georgia,serif;color:var(--emerald);font-size:1.15rem;margin:12px 0 1px;}
  .ing-card .lat{font-size:.74rem;color:var(--gold);font-style:italic;margin-bottom:8px;}
  .ing-card p{font-size:.88rem;color:var(--muted);}

  /* benefits */
  .benefits{background:var(--emerald);color:#e8eedd;}
  .benefits .sec-head h2{color:#f3ecd8;}
  .ben-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:760px;margin:0 auto;}
  .ben{display:flex;gap:14px;align-items:flex-start;background:rgba(255,255,255,.05);border:1px solid rgba(205,176,121,.25);border-radius:12px;padding:16px 18px;}
  .ben .bi{color:var(--gold-l);font-size:1.3rem;line-height:1;}
  .ben b{color:#f3ecd8;display:block;font-size:.98rem;}
  .ben span{font-size:.85rem;color:#cfc6ac;}

  /* how to use */
  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
  .step{text-align:center;background:#fff;border:1px solid #ece2cc;border-radius:14px;padding:24px 16px;}
  .step .n{font-family:Georgia,serif;font-size:1.8rem;color:var(--gold-l);font-weight:700;}
  .step p{font-size:.85rem;color:var(--muted);margin-top:6px;}

  /* CTA */
  .cta{background:linear-gradient(135deg,var(--gold),#a07d3e);color:#fff;text-align:center;border-radius:18px;padding:40px 24px;margin:10px auto 0;}
  .cta h2{font-family:Georgia,serif;font-size:1.8rem;margin-bottom:8px;}
  .cta p{opacity:.95;}
  .cta .btn{display:inline-block;margin-top:18px;background:var(--emerald);color:#f3ecd8;padding:13px 30px;border-radius:30px;text-decoration:none;font-size:.9rem;letter-spacing:.04em;}

  footer{background:var(--emerald);color:#9fb088;text-align:center;padding:30px 0;font-size:.8rem;}
  footer .b{color:var(--gold-l);letter-spacing:.3em;font-size:.95rem;margin-bottom:6px;}

  @media(max-width:760px){
    .hero h1{font-size:2.1rem;}
    .ing-grid{grid-template-columns:1fr;}
    .ben-grid{grid-template-columns:1fr;}
    .steps{grid-template-columns:repeat(2,1fr);}
    .hero{justify-content:center;text-align:center;}
    .hero .badges{justify-content:center;}
  }
</style>
</head>
