---
import BaseLayout from '../layouts/BaseLayout.astro';
import Photo from '../components/Photo.astro';
import { site } from '../config/site';

const pillars = [
  { title: 'Waste-to-value sourcing', body: 'We convert rice husk — an agricultural residue too often burned in the open — into high-value silica and clean fuel, keeping material and carbon in a productive loop.' },
  { title: 'Lower-carbon products', body: 'RHA replaces a share of energy-intensive cement clinker, and rice husk pellets offer a renewable, carbon-neutral alternative to coal — cutting emissions downstream.' },
  { title: 'Supporting farmers', body: 'Creating steady demand for husk turns a disposal problem into rural income and helps end open-field burning around our milling base.' },
  { title: 'Responsible operations', body: 'We aim for clean, efficient processing with minimal waste, and screened, well-managed material across every grade we ship.' },
];

const stats = [
  { big: '100%', label: 'Waste-to-value sourcing' },
  { big: 'Zero', label: 'Open-field husk burning' },
  { big: 'Carbon-neutral', label: 'Biomass fuel products' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'CSR & Sustainability', item: site.url + '/csr/' },
  ],
};
---

<BaseLayout
  title="CSR & Sustainability — Circular Economy of Rice Husk | Ambika Biotech"
  description="How Ambika Biotech turns rice husk waste into high-value silica and clean biomass fuel — a circular, lower-carbon model that supports farmers and ends open-field burning."
  path="/csr/"
  jsonLd={[breadcrumb]}
>
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container crumb-inner">
      <a href="/">Home</a><span>/</span><span class="crumb-current">CSR &amp; Sustainability</span>
    </div>
  </nav>

  <section class="csr-hero">
    <div class="container csr-hero-grid">
      <div data-reveal>
        <div class="eyebrow">CSR &amp; Sustainability</div>
        <h1 class="csr-h1">A circular economy, by design</h1>
        <p class="csr-lead">Rice husk is an agricultural by-product that is too often burned as waste. We turn it into high-value silica and clean biomass fuel — keeping carbon and material in a productive loop, and giving farmers and industry a sustainable alternative.</p>
        <div class="csr-stats">
          {stats.map((s) => (
            <div><div class="csr-big">{s.big}</div><div class="csr-sm">{s.label}</div></div>
          ))}
        </div>
      </div>
      <div data-reveal>
        <div class="csr-img"><Photo src="/images/sections/rice-fields-packing.webp" alt="Lush green paddy rice fields near Sambalpur, Odisha — circular, sustainable rice husk sourcing by Ambika Biotech" width={1100} height={733} /></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container csr-intro" data-reveal>
      <div class="eyebrow">The Loop</div>
      <h2 class="csr-h2">From milling by-product to industrial silica and clean fuel</h2>
      <p class="body-p">Every tonne of milled rice yields roughly 200 kg of husk. Rather than letting that husk go to waste, we channel it into two valuable lives: a renewable biomass fuel, and — from the ash that remains after combustion — a high-purity industrial silica. One residue therefore displaces both fossil fuel and a portion of energy-intensive cement clinker.</p>
    </div>
    <div class="container">
      <div class="pillars-grid">
        {pillars.map((p) => (
          <div class="pillar" data-reveal>
            <span class="pillar-dot" aria-hidden="true"></span>
            <h3 class="pillar-title">{p.title}</h3>
            <p class="pillar-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="band-wrap">
    <div class="container" data-reveal>
      <div class="cta-band">
        <div>
          <h2 class="cb-h2">Build with a lower-carbon supply partner</h2>
          <p class="cb-p">From pozzolanic RHA for greener concrete to carbon-neutral biomass pellets — let's talk about your requirement.</p>
        </div>
        <a href="/contact/#quote-form" class="btn btn-gold">Get a Quote <span class="mono">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb { border-bottom: 1px solid #efe9d9; background: var(--cream); }
  .crumb-inner { display: flex; align-items: center; gap: 10px; padding: 14px 32px; font-size: 13.5px; color: var(--text-faint); }
  .crumb-inner a { color: var(--text-faint); text-decoration: none; }
  .crumb-inner span { opacity: 0.5; }
  .crumb-current { color: var(--green-800) !important; font-weight: 600; opacity: 1 !important; }

  .csr-hero { padding: 64px 0 80px; background: radial-gradient(110% 80% at 88% 0%, #eef3ea 0%, var(--cream) 55%); }
  .csr-hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; }
  .csr-h1 { font-family: var(--font-head); font-weight: 800; font-size: 48px; line-height: 1.06; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 20px; }
  .csr-lead { font-size: 18px; line-height: 1.65; color: var(--text-soft); margin-bottom: 28px; }
  .csr-stats { display: flex; gap: 36px; flex-wrap: wrap; }
  .csr-big { font-family: var(--font-head); font-weight: 800; font-size: 28px; color: var(--green-600); line-height: 1; }
  .csr-sm { font-size: 13.5px; color: var(--text-faint); margin-top: 6px; }
  .csr-img { position: relative; width: 100%; aspect-ratio: 1/1; border-radius: 20px; overflow: hidden; background: var(--cream-2); }
  .csr-img .media { position: absolute; inset: 0; }

  .csr-intro { max-width: 820px; margin-bottom: 44px; }
  .csr-h2 { font-family: var(--font-head); font-weight: 800; font-size: 34px; line-height: 1.12; color: var(--ink); margin-bottom: 16px; }
  .body-p { font-size: 17px; line-height: 1.7; color: var(--text-soft); }

  .pillars-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; }
  .pillar { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 30px 28px; }
  .pillar-dot { display: block; width: 14px; height: 14px; border-radius: 50%; background: var(--gold-600); margin-bottom: 16px; }
  .pillar-title { font-family: var(--font-head); font-weight: 700; font-size: 19px; color: var(--ink); margin-bottom: 10px; }
  .pillar-body { font-size: 15px; line-height: 1.6; color: var(--text-muted); }

  .band-wrap { padding-bottom: var(--section-y); }
  .cta-band { position: relative; overflow: hidden; background: var(--green-800); border-radius: 24px; padding: 56px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cb-h2 { font-family: var(--font-head); font-weight: 800; font-size: 32px; line-height: 1.14; color: var(--cream); margin-bottom: 12px; max-width: 620px; }
  .cb-p { font-size: 16.5px; color: #bfcbba; max-width: 540px; }

  @media (max-width: 1024px) { .csr-h1 { font-size: 38px; } .csr-h2 { font-size: 28px; } }
  @media (max-width: 860px) { .csr-hero-grid { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 640px) { .csr-h1 { font-size: 30px; } .pillars-grid { grid-template-columns: 1fr; } .cta-band { padding: 34px 24px; } .cta-band .btn { width: 100%; justify-content: center; } }
</style>
