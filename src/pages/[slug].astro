---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import ProductCard from '../components/ProductCard.astro';
import Shape from '../components/Shape.astro';
import { site } from '../config/site';
import { products, getProduct, categories, SPEC_NOTE } from '../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const p = getProduct(slug!)!;
const cat = categories[p.category];
const related = p.related.map((s) => getProduct(s)!).filter(Boolean);
const waMessage = 'Hello Ambika Biotech, I would like a quote for ' + p.name + '.';
const waLink = 'https://wa.me/' + site.whatsapp + '?text=' + encodeURIComponent(waMessage);

const whyPoints = [
  { num: '01', title: 'Consistent quality', body: 'A uniform spec delivered batch after batch — predictable performance every time.' },
  { num: '02', title: 'NABL-tested', body: 'Independently verified parameters, with documentation supplied against your order.' },
  { num: '03', title: 'Bulk & export', body: 'Reliable volumes, jumbo-bag packing and full export paperwork for smooth shipping.' },
];

const path = `/${p.slug}/`;
const productImage = new URL('/og-default.svg', site.url).href;

const specProps = p.specs.map((s) => ({
  '@type': 'PropertyValue',
  name: s.k,
  value: s.v,
}));

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: p.name,
  description: p.metaDescription,
  category: cat.name,
  image: productImage,
  url: new URL(path, site.url).href,
  brand: { '@type': 'Brand', name: site.brand },
  manufacturer: { '@id': site.url + '#organization' },
  additionalProperty: specProps,
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Products', item: site.url + '/products/' },
    { '@type': 'ListItem', position: 3, name: cat.name, item: new URL(`/${cat.slug}/`, site.url).href },
    { '@type': 'ListItem', position: 4, name: p.name, item: new URL(path, site.url).href },
  ],
};
---

<BaseLayout
  title={p.seoTitle}
  description={p.metaDescription}
  path={path}
  quoteHref="#quote-form"
  jsonLd={[productSchema, breadcrumb]}
>
  <!-- Breadcrumb -->
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container crumb-inner">
      <a href="/">Home</a><span>/</span>
      <a href="/products/">Products</a><span>/</span>
      <a href={`/${cat.slug}/`}>{cat.name}</a><span>/</span>
      <span class="crumb-current">{p.shortName}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="p-hero">
    <div class="container p-hero-grid">
      <div data-reveal>
        <div class="p-img ph ph-dark">
          <span class="ph-label ph-label-dark">{p.photoLabel}</span>
          <div class="p-img-badge">
            <div class="pib-big">{p.statBig}</div>
            <div class="pib-label">{p.statLabel}</div>
          </div>
        </div>
        <div class="p-thumbs" aria-hidden="true">
          <div class="ph p-thumb"></div>
          <div class="ph p-thumb"></div>
          <div class="ph p-thumb"></div>
        </div>
      </div>
      <div data-reveal>
        <div class="eyebrow">Product · {p.code}</div>
        <h1 class="p-h1">{p.name}</h1>
        <p class="p-value">{p.value}</p>
        <div class="p-tags">
          {p.tags.map((t) => (
            <span class="p-tag"><span class="p-tag-dot"></span>{t}</span>
          ))}
        </div>
        <div class="p-cta">
          <a href="#quote-form" class="btn btn-primary">Get a Quote <span class="mono">→</span></a>
          <a href={waLink} class="btn btn-whatsapp" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section section-white">
    <div class="container split">
      <div data-reveal>
        <div class="eyebrow">Overview</div>
        <h2 class="split-h2">{p.overviewHeading}</h2>
      </div>
      <div data-reveal>
        {p.overview.map((para) => <p class="body-p">{para}</p>)}
      </div>
    </div>
  </section>

  <!-- Specifications -->
  <section class="section">
    <div class="container split">
      <div data-reveal>
        <div class="eyebrow">Specifications</div>
        <h2 class="split-h2">Technical data sheet</h2>
        <p class="spec-note">{SPEC_NOTE}</p>
        <p class="pack-note"><strong>Packing:</strong> {p.packing}</p>
        <a href="/test-report-sample.pdf" class="link-underline" target="_blank" rel="noopener">
          Download sample test report <span class="mono">→</span>
        </a>
      </div>
      <div data-reveal class="spec-table">
        {p.specs.map((s) => (
          <div class="spec-row">
            <span class="spec-k">{s.k}</span>
            <span class="spec-v">{s.v}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section section-white">
    <div class="container">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">Key Benefits</div>
        <h2 class="split-h2">Why buyers choose {p.shortName}</h2>
      </div>
      <div class="benefit-grid">
        {p.benefits.map((b) => (
          <div class="benefit" data-reveal>
            <span class="benefit-check" aria-hidden="true">✓</span>
            <span>{b}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="section">
    <div class="container">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">Applications</div>
        <h2 class="split-h2">Where {p.shortName} is used</h2>
      </div>
      <div class="app-grid">
        {p.applications.map((a) => (
          <div class="app-card" data-reveal>
            <div class="app-icon"><Shape type={a.shape} color={a.color} /></div>
            <div>
              <h3 class="app-title">{a.title}</h3>
              <p class="app-note">{a.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why buy -->
  <section class="section section-white">
    <div class="container">
      <div class="sec-head" data-reveal>
        <div class="eyebrow">Why Buy From Ambika Biotech</div>
        <h2 class="split-h2">A supply partner, not just a seller</h2>
      </div>
      <div class="why3-grid">
        {whyPoints.map((w) => (
          <div class="why3-card" data-reveal>
            <div class="why3-num">{w.num}</div>
            <h3 class="why3-title">{w.title}</h3>
            <div class="why3-rule"></div>
            <p class="why3-body">{w.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related products -->
  <section class="section">
    <div class="container">
      <div class="prod-head" data-reveal>
        <div>
          <div class="eyebrow">Related Products</div>
          <h2 class="split-h2">More from {cat.name}</h2>
        </div>
        <a href={`/${cat.slug}/`} class="link-underline">All {cat.name} <span class="mono">→</span></a>
      </div>
      <div class="related-grid">
        {related.map((r) => <ProductCard product={r} />)}
      </div>
    </div>
  </section>

  <!-- Bottom quote CTA -->
  <section class="contact-sec">
    <div class="container contact-grid">
      <div data-reveal>
        <div class="eyebrow eyebrow-gold">Request a Quote</div>
        <h2 class="contact-h2">Request a quote for <span class="gold">{p.shortName}</span></h2>
        <p class="contact-p">Share your volume, target spec and destination — we reply within one business day with pricing, lead time and documentation.</p>
        <div class="contact-actions">
          <a href={waLink} class="ca ca-wa" target="_blank" rel="noopener"><span class="ca-ic">◎</span> Chat on WhatsApp</a>
          <a href={`tel:${site.phoneE164}`} class="ca ca-call"><span class="ca-ic ca-ic-gold">●</span> {site.phoneDisplay}</a>
        </div>
        <div class="enquiry-pill">
          <span class="ep-key">ENQUIRY FOR</span>
          <span class="ep-val">{p.name}</span>
        </div>
      </div>
      <div data-reveal id="quote-form">
        <QuoteForm source={`Product: ${p.name}`} preselect={p.name} formId="product-rfq" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-white { background: #fff; border-top: 1px solid #efe9d9; border-bottom: 1px solid #efe9d9; }
  .split-h2 { font-family: var(--font-head); font-weight: 800; font-size: 34px; line-height: 1.12; color: var(--ink); margin-bottom: 16px; }
  .body-p { font-size: 17px; line-height: 1.7; color: var(--text-soft); margin-bottom: 18px; }

  /* Breadcrumb */
  .crumb { border-bottom: 1px solid #efe9d9; background: var(--cream); }
  .crumb-inner { display: flex; align-items: center; gap: 10px; padding: 14px 32px; font-size: 13.5px; color: var(--text-faint); flex-wrap: wrap; }
  .crumb-inner a { color: var(--text-faint); text-decoration: none; }
  .crumb-inner a:hover { color: var(--green-800); }
  .crumb-inner span { opacity: 0.5; }
  .crumb-current { color: var(--green-800) !important; font-weight: 600; opacity: 1 !important; }

  /* Hero */
  .p-hero { padding: 56px 0 88px; background: radial-gradient(110% 80% at 12% 0%, #eef3ea 0%, var(--cream) 50%); }
  .p-hero-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 60px; align-items: center; }
  .p-img { position: relative; width: 100%; aspect-ratio: 1/1; border-radius: 22px; overflow: hidden; box-shadow: 0 30px 60px -24px rgba(14, 42, 29, 0.55); }
  .p-img-badge { position: absolute; top: 20px; left: 20px; background: var(--cream); border-radius: 14px; padding: 14px 16px; box-shadow: 0 10px 24px rgba(0,0,0,0.18); }
  .pib-big { font-family: var(--font-head); font-weight: 800; font-size: 26px; color: var(--green-800); line-height: 1; }
  .pib-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.12em; color: var(--gold-700); margin-top: 5px; }
  .p-thumbs { display: flex; gap: 12px; margin-top: 14px; }
  .p-thumb { flex: 1; aspect-ratio: 1/1; border-radius: 12px; }
  .p-h1 { font-family: var(--font-head); font-weight: 800; font-size: 46px; line-height: 1.05; letter-spacing: -0.024em; color: var(--ink); margin-bottom: 18px; }
  .p-value { font-size: 18.5px; line-height: 1.6; color: var(--text-soft); max-width: 520px; margin-bottom: 26px; }
  .p-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
  .p-tag { display: inline-flex; align-items: center; gap: 8px; background: var(--tile); border: 1px solid #d4e0d2; color: var(--green-600); font-size: 13px; font-weight: 600; padding: 8px 14px; border-radius: 999px; }
  .p-tag-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold-600); }
  .p-cta { display: flex; gap: 14px; flex-wrap: wrap; }

  /* Split sections */
  .split { display: grid; grid-template-columns: 0.42fr 0.58fr; gap: 60px; align-items: start; }
  .spec-note { font-size: 14px; line-height: 1.55; color: var(--gold-700); background: #fcf7ec; border: 1px solid #efe2c8; border-radius: 10px; padding: 12px 14px; margin-bottom: 16px; }
  .pack-note { font-size: 15px; color: var(--text-muted); margin-bottom: 18px; }
  .spec-table { background: #fff; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; box-shadow: 0 14px 32px -22px rgba(14,42,29,0.22); }
  .spec-row { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 16px 26px; border-bottom: 1px solid #f1ecdd; }
  .spec-row:last-child { border-bottom: none; }
  .spec-k { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.08em; color: #8a8470; text-transform: uppercase; }
  .spec-v { font-family: var(--font-head); font-weight: 700; font-size: 16px; color: var(--ink); text-align: right; }

  /* Section head */
  .sec-head { margin-bottom: 40px; max-width: 640px; }
  .prod-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 40px; flex-wrap: wrap; }

  /* Benefits */
  .benefit-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .benefit { display: flex; gap: 14px; align-items: flex-start; background: var(--cream); border: 1px solid var(--line); border-radius: 14px; padding: 20px 22px; font-size: 15.5px; color: var(--text); line-height: 1.5; }
  .benefit-check { flex: none; width: 26px; height: 26px; border-radius: 50%; background: var(--tile); color: var(--green-600); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; }

  /* Applications */
  .app-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .app-card { background: var(--cream); border: 1px solid var(--line); border-radius: 16px; padding: 26px; display: flex; gap: 18px; align-items: flex-start; transition: transform .25s ease, border-color .25s ease; }
  .app-card:hover { transform: translateY(-4px); border-color: var(--gold-600); }
  .app-icon { flex: none; width: 46px; height: 46px; border-radius: 12px; background: var(--tile); display: flex; align-items: center; justify-content: center; }
  .app-title { font-family: var(--font-head); font-weight: 700; font-size: 17.5px; color: var(--ink); margin-bottom: 7px; }
  .app-note { font-size: 14px; line-height: 1.55; color: var(--text-muted); }

  /* Why 3 */
  .why3-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .why3-card { background: var(--cream); border: 1px solid var(--line); border-radius: 16px; padding: 32px 28px; }
  .why3-num { width: 46px; height: 46px; border-radius: 12px; background: var(--tile); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-weight: 800; font-size: 17px; color: var(--green-600); margin-bottom: 18px; }
  .why3-title { font-family: var(--font-head); font-weight: 700; font-size: 19px; color: var(--ink); margin-bottom: 8px; }
  .why3-rule { width: 34px; height: 2px; background: var(--gold-600); border-radius: 2px; margin-bottom: 14px; }
  .why3-body { font-size: 14.5px; line-height: 1.6; color: var(--text-muted); }

  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }

  /* Contact (shared look) */
  .contact-sec { background: var(--green-800); padding: 120px 0; }
  .contact-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 56px; align-items: start; }
  .eyebrow-gold { color: var(--gold); }
  .gold { color: var(--gold); }
  .contact-h2 { font-family: var(--font-head); font-weight: 800; font-size: 38px; line-height: 1.1; color: var(--cream); margin-bottom: 18px; }
  .contact-p { font-size: 16.5px; line-height: 1.6; color: #bfcbba; margin-bottom: 30px; max-width: 440px; }
  .contact-actions { display: flex; flex-direction: column; gap: 14px; margin-bottom: 24px; }
  .ca { display: flex; align-items: center; gap: 14px; padding: 16px 20px; border-radius: 13px; text-decoration: none; font-weight: 600; font-size: 15.5px; transition: transform .18s ease; }
  .ca:hover { transform: translateY(-2px); }
  .ca-wa { background: var(--whatsapp); color: #fff; }
  .ca-call { background: rgba(255,255,255,0.06); color: var(--cream); border: 1px solid rgba(255,255,255,0.14); }
  .ca-ic { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,0.16); display: flex; align-items: center; justify-content: center; font-size: 16px; }
  .ca-ic-gold { background: rgba(230,199,122,0.18); color: var(--gold); }
  .enquiry-pill { display: inline-flex; align-items: center; gap: 10px; border: 1px solid rgba(255,255,255,0.14); border-radius: 999px; padding: 8px 16px; }
  .ep-key { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--gold); }
  .ep-val { font-size: 13.5px; color: var(--cream); font-weight: 600; }

  @media (max-width: 1024px) {
    .p-h1 { font-size: 38px; }
    .split-h2, .contact-h2 { font-size: 28px; }
    .app-grid, .why3-grid, .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 860px) {
    .p-hero-grid, .split, .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .contact-sec { padding: 72px 0; }
  }
  @media (max-width: 640px) {
    .p-h1 { font-size: 31px; }
    .benefit-grid, .app-grid, .why3-grid, .related-grid { grid-template-columns: 1fr; }
    .p-cta .btn { width: 100%; justify-content: center; }
  }
</style>
