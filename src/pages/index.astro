---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import QuoteForm from '../components/QuoteForm.astro';
import ProductCard from '../components/ProductCard.astro';
import Photo from '../components/Photo.astro';
import Icon from '../components/Icon.astro';
import { site } from '../config/site';
import { products, categories } from '../data/products';

// Only pure-integer stats animate (num + suffix). Range values (85–92%) and
// text values (NABL) render statically — they cannot count up.
const heroStats = [
  { num: 20, suffix: '+', label: 'Years of manufacturing experience' },
  { static: 'NABL', label: 'NABL tested & certified quality' },
  { static: '85–92%', label: 'High-silica SiO₂ content' },
  { num: 3, suffix: '+', label: 'Export regions worldwide' },
];

const rha = products.filter((p) => p.category === 'rice-husk-ash');
const husk = products.filter((p) => p.category === 'rice-husk');

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;

const industries = [
  { name: 'Steel', note: 'Tundish & ladle covering' },
  { name: 'Concrete / Construction', note: 'Pozzolana & SCM' },
  { name: 'Refractory', note: 'High-temp insulation' },
  { name: 'Biomass Energy', note: 'Fuel pellets & husk' },
  { name: 'Agriculture / Feed', note: 'Feed, bedding, fillers' },
] as const;

const title = 'Rice Husk Ash Manufacturer & Exporter India | Ambika Biotech';
const description =
  'Ambika Biotech (RHA India) — rice husk ash manufacturer, supplier & exporter in Sambalpur, Odisha. High-silica RHA (85–92% SiO₂), granules, pellets & rice husk products. NABL tested. Get a bulk quote/price.';

const webPage = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  publisher: { '@id': site.url + '#organization' },
};
---

<BaseLayout title={title} description={description} path="/" quoteHref="#quote-form" jsonLd={[webPage]}>
  <!-- ===================== HERO CAROUSEL ===================== -->
  <HeroCarousel />

  <!-- ===================== TRUST STRIP (count-up) ===================== -->
  <section class="trust-strip snap-sec">
    <div class="container">
      <div class="trust-grid" data-reveal data-countup>
        {heroStats.map((t) => (
          <div class="trust-item">
            <div class="trust-big">
              {t.static ? (
                <span>{t.static}</span>
              ) : (
                <span><span class="count" data-count={t.num}>0</span>{t.suffix}</span>
              )}
            </div>
            <div class="trust-label">{t.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CERTIFICATION BAND ===================== -->
  <section class="cert-band snap-sec">
    <div class="container cert-inner" data-reveal>
      <div class="cert-left">
        <span class="nabl-badge" aria-label="NABL Lab-tested quality">
          <span class="nabl-mark">NABL</span>
          <span class="nabl-text">
            <span class="nabl-line">Lab-tested</span>
            <span class="nabl-line">quality</span>
          </span>
        </span>
        <p class="cert-copy">
          Independent NABL-tested material with documented parameters for every grade —
          the assurance export buyers and procurement teams require.
        </p>
      </div>
      <a href="/test-report-sample.pdf" class="link-underline" target="_blank" rel="noopener">
        Download sample test report (PDF) <span class="mono">→</span>
      </a>
    </div>
  </section>

  <!-- ===================== PRODUCTS ===================== -->
  <section id="products" class="section section-white snap-sec">
    <div class="container">
      <div class="prod-head" data-reveal>
        <div>
          <div class="eyebrow">Our Product Range</div>
          <h2 class="h2">Six products. One reliable supplier.</h2>
        </div>
        <a href="/products/" class="link-underline">All products <span class="mono">→</span></a>
      </div>

      <div class="cat-label" data-reveal>
        <span class="cat-tag">Category A</span>
        <a href="/rice-husk-ash/" class="cat-name-link"><h3 class="cat-name">{categories['rice-husk-ash'].name}</h3></a>
        <span class="cat-blurb">{categories['rice-husk-ash'].blurb}</span>
      </div>
      <div class="prod-grid">
        {rha.map((p) => <ProductCard product={p} />)}
      </div>

      <div class="cat-label cat-label-2" data-reveal>
        <span class="cat-tag">Category B</span>
        <a href="/rice-husk/" class="cat-name-link"><h3 class="cat-name">{categories['rice-husk'].name}</h3></a>
        <span class="cat-blurb">{categories['rice-husk'].blurb}</span>
      </div>
      <div class="prod-grid">
        {husk.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <!-- ===================== QUOTE BAND ===================== -->
  <section class="band-wrap snap-sec">
    <div class="container" data-reveal>
      <div class="quote-band">
        <div class="qb-ring qb-ring-1" aria-hidden="true"></div>
        <div class="qb-ring qb-ring-2" aria-hidden="true"></div>
        <div class="qb-text">
          <h2 class="qb-h2">Need a quote for bulk RHA or rice husk products?</h2>
          <p class="qb-p">Send your spec and volume — we reply with pricing, lead time and export documentation.</p>
        </div>
        <a href="#quote-form" class="btn btn-gold qb-cta">Get a Quote <span class="mono">→</span></a>
      </div>
    </div>
  </section>

  <!-- ===================== INDUSTRIES ===================== -->
  <section class="section section-white snap-sec">
    <div class="container">
      <div class="ind-head" data-reveal>
        <div class="eyebrow">Industries We Serve</div>
        <h2 class="h2">From the furnace to the field</h2>
      </div>
      <div class="ind-grid">
        {industries.map((ind) => (
          <div class="ind-card" data-reveal>
            <div class="ind-icon"><Icon label={ind.name} note={ind.note} /></div>
            <div>
              <h3 class="ind-name">{ind.name}</h3>
              <p class="ind-note">{ind.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CSR ===================== -->
  <section class="section csr-section snap-sec">
    <div class="container csr-grid">
      <div data-reveal>
        <div class="eyebrow">CSR &amp; Sustainability</div>
        <h2 class="h2">A circular economy, by design</h2>
        <p class="lead">
          Rice husk is an agricultural by-product that is too often burned as waste. We turn
          it into high-value silica and clean biomass fuel — keeping carbon and material in a
          productive loop, and giving farmers and industry a sustainable alternative.
        </p>
        <div class="csr-stats">
          <div class="csr-stat">
            <div class="csr-big">100%</div>
            <div class="csr-sm">Waste-to-value sourcing</div>
          </div>
          <div class="csr-stat">
            <div class="csr-big">Zero</div>
            <div class="csr-sm">Open-field husk burning</div>
          </div>
        </div>
        <a href="/csr/" class="btn btn-outline csr-link">Read our CSR story <span class="mono">→</span></a>
      </div>
      <div data-reveal>
        <div class="csr-img">
          <Photo src="/images/sections/rice-fields-packing.webp" alt="Lush green paddy rice fields near Sambalpur, Odisha — sustainable rice husk sourcing by Ambika Biotech" width={1100} height={733} />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT / QUOTE ===================== -->
  <section id="contact" class="contact-sec">
    <div class="container contact-grid">
      <div data-reveal>
        <div class="eyebrow eyebrow-gold">Get a Quote</div>
        <h2 class="contact-h2">Let's talk volume, spec &amp; shipping</h2>
        <p class="contact-p">Tell us what you need. Our team replies within one business day with pricing and lead time.</p>

        <div class="contact-actions">
          <a href={waLink} class="ca ca-wa" target="_blank" rel="noopener">
            <span class="ca-ic">◎</span> Chat on WhatsApp
          </a>
          <a href={`tel:${site.phoneE164}`} class="ca ca-call">
            <span class="ca-ic ca-ic-gold">●</span> {site.phoneDisplay}
          </a>
        </div>

        <div class="contact-meta">
          <div class="cm-row">
            <span class="cm-key">ADDRESS</span>
            <span class="cm-val">{site.address.full}</span>
          </div>
          <div class="cm-row">
            <span class="cm-key">EMAIL</span>
            <a class="cm-val cm-link" href={`mailto:${site.email}`}>{site.email}</a>
          </div>
          <div class="cm-row">
            <span class="cm-key">GSTIN</span>
            <span class="cm-val">{site.gstin}</span>
          </div>
          <div class="map-wrap">
            <iframe
              title="Ambika Biotech location on Google Maps"
              src={`https://www.google.com/maps?q=${site.mapsEmbedQuery}&z=14&output=embed`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </div>

      <div data-reveal id="quote-form">
        <QuoteForm source="Homepage" formId="home-rfq" />
      </div>
    </div>
  </section>

  <!-- ============= SECTION SCROLL NAV (homepage only) ============= -->
  <div class="section-nav">
    <button class="sn-btn sn-up" data-sn-up type="button" aria-label="Scroll to previous section" hidden>
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15l6-6 6 6" /></svg>
    </button>
    <button class="sn-btn sn-down" data-sn-down type="button" aria-label="Scroll to next section">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6" /></svg>
    </button>
  </div>

  <style is:global>
    /* --- Section-by-section scroll snap: HOMEPAGE ONLY (html.home-snap set by JS) --- */
    /* PROXIMITY (not mandatory) so users are never trapped and free scrolling still works. */
    html.home-snap { scroll-snap-type: y proximity; }
    /* Navbar clearance is provided by the existing global scroll-padding-top:90px, so
       snapped/target section tops sit just below the sticky ~74px header (never hidden). */
    html.home-snap .hero-carousel,
    html.home-snap .snap-sec {
      scroll-snap-align: start;
      scroll-snap-stop: normal;
    }
    /* Tall sections (contact form, footer) are NOT snap targets — they lack .snap-sec,
       and proximity snap never traps them. */
    @media (max-width: 860px) {
      html.home-snap { scroll-snap-type: none; } /* natural scrolling on mobile */
    }
    @media (prefers-reduced-motion: reduce) {
      html.home-snap { scroll-snap-type: none; }
    }

    /* Floating up/down section navigation — offset ABOVE the WhatsApp/Call FAB so
       they never collide; low z-index so native form dropdowns always render on top. */
    .section-nav {
      position: fixed;
      right: 24px;
      bottom: 170px;
      z-index: 40;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .section-nav .sn-btn {
      width: 42px; height: 42px; border-radius: 50%;
      border: 1px solid var(--line-3);
      background: rgba(255, 255, 255, 0.92);
      color: var(--green-800);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      box-shadow: 0 8px 20px -6px rgba(14, 42, 29, 0.3);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
      transition: transform 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
    }
    .section-nav .sn-btn:hover { transform: translateY(-2px); background: #fff; box-shadow: 0 12px 24px -8px rgba(14, 42, 29, 0.4); }
    .section-nav .sn-btn[hidden] { display: none; }
    @media (max-width: 860px) { .section-nav { display: none; } }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var behavior = reduce ? 'auto' : 'smooth';

      // Enable gentle proximity scroll-snap on the homepage only. Skipped for
      // reduced-motion users (CSS also disables it there and on mobile).
      if (!reduce) root.classList.add('home-snap');

      var nav = document.querySelector('.section-nav');
      if (!nav) return;
      var upBtn = nav.querySelector('[data-sn-up]');
      var downBtn = nav.querySelector('[data-sn-down]');
      var sections = Array.prototype.slice.call(document.querySelectorAll('#main > section'));
      if (sections.length < 2) { nav.style.display = 'none'; return; }

      // Sections rest with their top at ~NAV px (the global scroll-padding-top),
      // just below the sticky ~74px navbar. We decide next/prev live from each
      // section's current rect.top — never from a stale index — so clicks never
      // "stop working". A ±BAND tolerance ignores the section currently resting
      // at the top so down/up always move to a genuinely different section.
      var NAV = 90;
      var BAND = 12;

      function maxScroll() {
        return document.documentElement.scrollHeight - window.innerHeight;
      }
      // First section whose top is meaningfully BELOW the navbar line.
      function nextSection() {
        for (var i = 0; i < sections.length; i++) {
          if (sections[i].getBoundingClientRect().top > NAV + BAND) return sections[i];
        }
        return null;
      }
      // Last section whose top is meaningfully ABOVE the navbar line (tops
      // increase in DOM order, so stop once we pass the current one).
      function prevSection() {
        var found = null;
        for (var i = 0; i < sections.length; i++) {
          if (sections[i].getBoundingClientRect().top < NAV - BAND) found = sections[i];
          else break;
        }
        return found;
      }
      function goToEl(el) { el.scrollIntoView({ behavior: behavior, block: 'start' }); }

      if (downBtn) downBtn.addEventListener('click', function () {
        var el = nextSection();
        if (el) goToEl(el);
        else window.scrollTo({ top: maxScroll(), behavior: behavior }); // reach footer
      });
      if (upBtn) upBtn.addEventListener('click', function () {
        var el = prevSection();
        if (el) goToEl(el);
        else window.scrollTo({ top: 0, behavior: behavior });
      });

      function updateButtons() {
        var atTop = window.scrollY <= 8;
        var atBottom = window.scrollY >= maxScroll() - 8;
        if (upBtn) upBtn.hidden = atTop;
        if (downBtn) downBtn.hidden = atBottom;
      }
      updateButtons();
      window.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons);
    })();
  </script>

  <script is:inline>
    (function () {
      var group = document.querySelector('[data-countup]');
      if (!group) return;
      var hasAnimated = false;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var els = Array.prototype.slice.call(group.querySelectorAll('.count'));

      function animateEl(el) {
        var target = parseInt(el.getAttribute('data-count'), 10) || 0;
        if (reduce) { el.textContent = String(target); return; }
        var dur = 1500, t0 = null;
        function step(ts) {
          if (!t0) t0 = ts;
          var p = Math.min((ts - t0) / dur, 1);
          if (p >= 1) {
            // Never rely on interval math for the final value — set it exactly.
            el.textContent = String(target);
            return;
          }
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = String(Math.round(eased * target));
          requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      // Runs EXACTLY once, guarded by hasAnimated.
      function runOnce() {
        if (hasAnimated) return;
        hasAnimated = true;
        els.forEach(animateEl);
      }

      if (!('IntersectionObserver' in window)) { runOnce(); return; }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { runOnce(); io.disconnect(); }
        });
      }, { threshold: 0.4 });
      io.observe(group);
    })();
  </script>
</BaseLayout>

<style>
  .h2 {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 30px;
    line-height: 1.14;
    color: var(--ink);
    margin-bottom: 16px;
  }
  .lead { font-size: 16px; line-height: 1.6; color: var(--text-soft); margin-bottom: 14px; max-width: 560px; }
  .section-white {
    background: #fff;
    border-top: 1px solid #efe9d9;
    border-bottom: 1px solid #efe9d9;
  }

  /* Hero */
  .hero { background: radial-gradient(120% 90% at 85% 0%, #eef3ea 0%, var(--cream) 55%); }
  .hero-grid {
    padding: 104px 32px 116px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 64px;
    align-items: center;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--tile);
    border: 1px solid #d4e0d2;
    color: var(--green-600);
    font-size: 13px;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 999px;
    margin-bottom: 26px;
  }
  .pill-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold-600); }
  .hero-h1 {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 72px;
    line-height: 1.02;
    letter-spacing: -0.028em;
    color: var(--ink);
    margin-bottom: 22px;
  }
  .amp { color: var(--gold-600); }
  .hero-sub { font-size: 19px; line-height: 1.6; color: var(--text-soft); max-width: 520px; margin-bottom: 34px; }
  .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 34px; }
  .hero-trust {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--text-faint);
  }
  .ht-strong { color: var(--green-600); font-weight: 500; }
  .hero-trust .dot { opacity: 0.4; }

  .hero-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 4.4;
    border-radius: 22px;
    overflow: hidden;
    background: var(--green-800);
    box-shadow: 0 30px 60px -24px rgba(20, 42, 31, 0.55);
  }
  .hero-particles { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .float-particle { position: absolute; bottom: -24px; border-radius: 50%; opacity: 0.55; animation-name: floatUp; animation-timing-function: linear; animation-iteration-count: infinite; }
  .hero-photo-label { position: absolute; left: 50%; bottom: 22px; transform: translateX(-50%); }
  .hero-badge {
    position: absolute; top: 20px; right: 20px;
    background: var(--cream); border-radius: 14px; padding: 14px 16px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }
  .hb-big { font-family: var(--font-head); font-weight: 800; font-size: 26px; color: var(--green-800); line-height: 1; }
  .hb-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.12em; color: var(--gold-700); margin-top: 5px; }

  /* Trust strip */
  .trust-strip { background: var(--green-800); }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .trust-item {
    padding: 30px 26px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
    display: flex; flex-direction: column; gap: 7px;
  }
  .trust-item:last-child { border-right: none; }
  .trust-big { font-family: var(--font-head); font-weight: 800; font-size: 44px; color: var(--gold); line-height: 1; }
  .trust-label { font-size: 15px; color: #cbd6c7; line-height: 1.35; }

  /* Certification band */
  .cert-band { background: #fff; border-bottom: 1px solid #efe9d9; }
  .cert-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 30px; padding-top: 40px; padding-bottom: 40px; flex-wrap: wrap;
  }
  .cert-left { display: flex; align-items: center; gap: 20px; max-width: 720px; }
  .nabl-badge {
    flex: none; display: flex; align-items: center; gap: 10px;
    border: 2px solid var(--green-600); border-radius: 12px; padding: 10px 14px;
  }
  .nabl-mark { font-family: var(--font-head); font-weight: 800; font-size: 18px; color: var(--green-600); }
  .nabl-text { display: flex; flex-direction: column; font-size: 14.5px; line-height: 1.25; color: var(--text-faint); font-family: var(--font-mono); letter-spacing: 0.04em; }
  .nabl-line { display: block; }
  .cert-copy { font-size: 15px; color: var(--text-muted); line-height: 1.55; margin: 0; }

  /* About */
  .about-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 64px; align-items: center; }
  .about-img { width: 100%; aspect-ratio: 5 / 4; border-radius: 18px; overflow: hidden; background: var(--cream-2); }

  /* Products */
  #products { padding-top: 44px; padding-bottom: 44px; }
  .prod-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 14px; flex-wrap: wrap; }
  .prod-head .h2 { margin-bottom: 0; }
  .cat-label { display: flex; align-items: baseline; gap: 12px; margin-bottom: 8px; flex-wrap: wrap; }
  .cat-label-2 { margin-top: 12px; }
  .cat-tag {
    font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em;
    color: #fff; background: var(--green-600); padding: 4px 10px; border-radius: 999px; text-transform: uppercase;
  }
  .cat-name-link { text-decoration: none; }
  .cat-name { font-family: var(--font-head); font-weight: 800; font-size: 16px; color: var(--ink); }
  .cat-name-link:hover .cat-name { color: var(--green-600); }
  .cat-blurb { font-size: 13.5px; color: var(--text-faint); }
  .prod-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

  /* Quote band */
  .band-wrap { padding-bottom: var(--section-y); }
  .quote-band {
    position: relative; overflow: hidden; background: var(--green-800);
    border-radius: 24px; padding: 56px;
    display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;
  }
  .qb-ring { position: absolute; border-radius: 50%; border: 1.5px solid rgba(230, 199, 122, 0.2); }
  .qb-ring-1 { right: -40px; top: -40px; width: 220px; height: 220px; animation: rotateSlow 95s linear infinite; }
  .qb-ring-2 { right: 30px; top: 30px; width: 130px; height: 130px; border-color: rgba(230, 199, 122, 0.16); }
  .qb-text { position: relative; }
  .qb-h2 { font-family: var(--font-head); font-weight: 800; font-size: 34px; line-height: 1.14; color: var(--cream); margin-bottom: 12px; max-width: 620px; }
  .qb-p { font-size: 16.5px; color: #bfcbba; max-width: 540px; }
  .qb-cta { position: relative; }

  /* Industries */
  .ind-head { margin-bottom: 46px; }
  .ind-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .ind-card {
    position: relative;
    overflow: hidden;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 30px 22px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
