---
// Lightweight auto-rotating image (crossfade) with an optional name caption
// that changes in sync. Fills its parent container, which sets the size
// (aspect-ratio / border-radius / overflow).
export interface Props {
  images: { src: string; alt: string; label?: string }[];
  interval?: number; // ms between slides
  eager?: boolean; // first image eager (above the fold)
  class?: string;
}
const { images, interval = 2500, eager = false, class: cls = '' } = Astro.props;
---
<div class:list={['img-rotator', cls]} data-rotator data-interval={interval}>
  {images.map((im, i) => (
    <div class:list={['ir-slide', { 'is-active': i === 0 }]}>
      <img
        class="ir-img"
        src={im.src}
        alt={i === 0 ? im.alt : ''}
        width="1200"
        height="900"
        loading={i === 0 && eager ? 'eager' : 'lazy'}
        fetchpriority={i === 0 && eager ? 'high' : 'auto'}
        decoding="async"
      />
      {im.label && (
        <div class="ir-caption"><span class="ir-dot"></span>{im.label}</div>
      )}
    </div>
  ))}
</div>

<style>
  .img-rotator { position: relative; width: 100%; height: 100%; }
  .ir-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .ir-slide.is-active { opacity: 1; }
  .ir-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .ir-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 40px 20px 18px;
    background: linear-gradient(transparent, rgba(8, 22, 15, 0.85));
    color: #fff;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .ir-dot { flex: none; width: 8px; height: 8px; border-radius: 50%; background: var(--gold); }
  @media (max-width: 640px) { .ir-caption { font-size: 15px; padding: 34px 16px 14px; } }
</style>

<script is:inline>
  (function () {
    function initRotator(root) {
      var slides = Array.prototype.slice.call(root.querySelectorAll('.ir-slide'));
      if (slides.length < 2) return;
      var delay = parseInt(root.getAttribute('data-interval'), 10) || 2500;
      var i = 0, timer = null;
      function step() {
        slides[i].classList.remove('is-active');
        i = (i + 1) % slides.length;
        var next = slides[i];
        var img = next.querySelector('.ir-img');
        if (img && img.loading === 'lazy') img.loading = 'eager';
        next.classList.add('is-active');
      }
      function play() { if (!timer) timer = setInterval(step, delay); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', play);
      document.addEventListener('visibilitychange', function () { if (document.hidden) stop(); else play(); });
      play();
    }
    function run() {
      Array.prototype.slice.call(document.querySelectorAll('[data-rotator]')).forEach(initRotator);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
  })();
</script>
