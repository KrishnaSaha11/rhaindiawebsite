---
// Picks a proper, recognizable inline SVG industry icon from a text label
// (industry name or application title). Replaces the old geometric placeholder
// shapes. Falls back to a generic factory icon when nothing matches.
export interface Props {
  label: string;
  /** Extra descriptive text to help keyword matching (e.g. the card note). */
  note?: string;
  size?: number;
}
const { label, note = '', size = 26 } = Astro.props;
const hay = `${label} ${note}`.toLowerCase();

type Key = 'steel' | 'foundry' | 'construction' | 'refractory' | 'agriculture' | 'energy' | 'industry';

function pick(text: string): Key {
  const has = (...w: string[]) => w.some((k) => text.includes(k));
  if (has('foundry', 'mould', 'mold', 'casting', 'pouring')) return 'foundry';
  if (has('steel', 'tundish', 'ladle', 'furnace', 'induction', 'arc', 'melt', 'metal')) return 'steel';
  if (has('concrete', 'construction', 'cement', 'precast', 'building', 'mortar')) return 'construction';
  if (has('refractor', 'brick', 'ceramic', 'kiln', 'lining', 'castable')) return 'refractory';
  if (has('agricultur', 'feed', 'fertil', 'soil', 'bedding', 'mushroom', 'poultry', 'cattle', 'horticultur', 'compost', 'organic')) return 'agriculture';
  if (has('boiler', 'fuel', 'energy', 'power', 'gasif', 'heating', 'biomass', 'briquette', 'pellet', 'co-firing', 'combust', 'thermal')) return 'energy';
  return 'industry';
}

const key = pick(hay);
const s = size;
---
{key === 'steel' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 20h16" /><path d="M6 20V10l6-4 6 4v10" /><path d="M9 20v-5h6v5" /><path d="M12 6V3" /><path d="M12 3l3 1.2" />
  </svg>
)}
{key === 'foundry' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M7 4h7l3 4v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z" /><path d="M9 13l-2 7h10l-2-7" /><path d="M11 8h2" />
  </svg>
)}
{key === 'construction' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="9" width="16" height="12" rx="1" /><path d="M9 21v-5h6v5" /><path d="M4 9l8-6 8 6" /><path d="M8 13h.01M12 13h.01M16 13h.01" />
  </svg>
)}
{key === 'refractory' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="5" width="18" height="14" rx="1" /><path d="M3 10h18M3 15h18" /><path d="M9 5v5M15 10v5M9 15v4M15 5v0" />
  </svg>
)}
{key === 'agriculture' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 21V11" /><path d="M12 11c0-4 3-7 8-7 0 4-3 7-8 7z" /><path d="M12 14C12 11 9 8 4 8c0 3 3 6 8 6z" />
  </svg>
)}
{key === 'energy' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3c1.5 3-1.5 4.5-1.5 7A3.5 3.5 0 0 0 15 13c.5-2.5-1-4 0-6 2 1.5 3.5 4 3.5 7a6.5 6.5 0 1 1-13 0c0-4 3-6.5 6.5-11z" />
  </svg>
)}
{key === 'industry' && (
  <svg width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 20h18" /><path d="M4 20V11l5 3V11l5 3V8l5-3v15" /><path d="M4 11V7" />
  </svg>
)}
