---
import { site } from '../config/site';
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<div class="floating-cta" aria-label="Quick contact">
  <!-- Call: compact icon-only button to reduce visual noise -->
  <a
    href={`tel:${site.phoneE164}`}
    class="fab-call"
    aria-label={`Call us on ${site.phoneDisplay}`}
  >
    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor">
      <path d="M6.62 10.79a15.46 15.46 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.24.2 2.45.57 3.57a1 1 0 01-.24 1.02l-2.21 2.2z"/>
    </svg>
  </a>
  <!-- WhatsApp: kept prominent -->
  <a
    href={waLink}
    class="fab fab-wa"
    target="_blank"
    rel="noopener"
    aria-label="Chat with us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="currentColor">
      <path d="M19.05 4.91A9.82 9.82 0 0012.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.86 9.86 0 004.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02zM12.04 20.15h-.01a8.2 8.2 0 01-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 01-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24a8.2 8.2 0 015.83 2.42 8.2 8.2 0 012.41 5.83c0 4.54-3.7 8.4-8.08 8.4zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.15.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/>
    </svg>
    <span class="fab-text">WhatsApp</span>
  </a>
</div>

<style>
  .floating-cta {
    position: fixed;
    right: 22px;
    bottom: 22px;
    /* Below the mobile drawer (70/71) and header (50 sticky is separate) so it
       never sits over an open menu. Native <select> popups render above all. */
    z-index: 45;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }
  .fab {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 18px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14.5px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .fab:hover { transform: translateY(-2px) scale(1.03); }
  .fab-wa { background: var(--whatsapp); color: #fff; box-shadow: 0 10px 24px rgba(31, 138, 76, 0.4); }
  .fab svg { flex: none; }

  /* Compact, secondary call button */
  .fab-call {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--green-800);
    color: var(--cream);
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(14, 42, 29, 0.35);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .fab-call:hover { transform: translateY(-2px) scale(1.05); }
  .fab-call svg { flex: none; }

  @media (max-width: 640px) {
    .floating-cta { right: 14px; bottom: 14px; gap: 10px; }
    .fab { padding: 13px; }
    .fab-text { display: none; }
  }
</style>
