---
import type { Product } from '../data/products';
import Photo from './Photo.astro';
export interface Props { product: Product; }
const { product } = Astro.props;
const cardImg = product.images?.[0];
---
<a href={`/${product.slug}/`} class="product-card" data-reveal>
  <div class="pc-img">
    <Photo src={cardImg?.src ?? `/images/products/${product.slug}.svg`} alt={cardImg?.alt ?? product.heroAlt} width={1200} height={900} />
    <span class="pc-chip">{product.categoryLabel}</span>
  </div>
  <div class="pc-body">
    <div class="pc-tag">{product.tag}</div>
    <h3 class="pc-title">{product.name}</h3>
    <div class="pc-rule"></div>
    <p class="pc-use">{product.use}</p>
    <span class="pc-more">View Specifications <span class="mono">→</span></span>
  </div>
</a>

<style>
  .product-card {
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .product-card:hover {
    border-color: var(--gold-600);
    transform: translateY(-8px);
    box-shadow: 0 30px 56px -24px rgba(14, 42, 29, 0.45);
  }
  .pc-img { position: relative; height: 110px; border-bottom: 1px solid var(--line); overflow: hidden; background: var(--cream-2); }
  .pc-img .media { transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
  .product-card:hover .pc-img .media { transform: scale(1.07); }
  .pc-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 31, 22, 0) 55%, rgba(12, 31, 22, 0.28) 100%);
    pointer-events: none;
  }
  .pc-chip {
    position: absolute;
    left: 14px;
    top: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: rgba(250, 246, 236, 0.92);
    border: 1px solid var(--line-3);
    padding: 6px 11px;
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }
  .pc-body { padding: 14px 16px; display: flex; flex-direction: column; flex: 1; }
  .pc-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--gold-700);
    margin-bottom: 5px;
  }
  .pc-title {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 16.5px;
    line-height: 1.18;
    color: var(--ink);
    margin-bottom: 6px;
    /* Reserve two lines so Category A and Category B cards align to equal height. */
    min-height: calc(2 * 1.18em);
  }
  .pc-rule { width: 28px; height: 2px; background: var(--gold-600); border-radius: 2px; margin-bottom: 8px; transition: width 0.3s ease; }
  .product-card:hover .pc-rule { width: 46px; }
  .pc-use { font-size: 14.5px; line-height: 1.45; color: var(--text-muted); margin-bottom: 10px; flex: 1; min-height: calc(2 * 1.45em); }
  .pc-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--green-800);
    font-weight: 600;
    font-size: 14px;
  }
  .pc-more .mono { font-family: var(--font-mono); transition: transform 0.25s ease; }
  .product-card:hover .pc-more .mono { transform: translateX(4px); color: var(--gold-700); }
</style>
