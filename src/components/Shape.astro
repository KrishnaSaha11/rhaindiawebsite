---
// Small geometric accent icon (matches the design's shape language).
export interface Props {
  type: 'circle' | 'diamond' | 'square' | 'ring' | 'triangle';
  color?: string;
}
const { type, color = '#27593C' } = Astro.props;
---
{type === 'circle' && <span class="shp" style={`width:20px;height:20px;border-radius:50%;background:${color}`}></span>}
{type === 'diamond' && <span class="shp" style={`width:18px;height:18px;background:${color};transform:rotate(45deg);border-radius:3px`}></span>}
{type === 'square' && <span class="shp" style={`width:19px;height:19px;background:${color};border-radius:4px`}></span>}
{type === 'ring' && <span class="shp" style={`width:20px;height:20px;border-radius:50%;border:4px solid ${color}`}></span>}
{type === 'triangle' && <span class="shp" style={`width:0;height:0;border-left:11px solid transparent;border-right:11px solid transparent;border-bottom:18px solid ${color}`}></span>}
<style>
  .shp { display: block; flex: none; }
</style>
