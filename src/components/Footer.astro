---
import { site } from '../config/site';
import { products } from '../data/products';
const year = new Date().getFullYear();
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand">
          <span class="fmark">R</span>
          <span class="ftext">
            <span class="fname">{site.name}</span>
            <span class="fsub">RHA INDIA</span>
          </span>
        </div>
        <p class="fdesc">
          Manufacturer &amp; exporter of high-silica Rice Husk Ash and rice husk
          products. {site.address.locality}, {site.address.region}, India.
        </p>
        <p class="fgst">GSTIN: {site.gstin}</p>
      </div>

      <div class="footer-col">
        <div class="fcol-head">Quick Links</div>
        <a href="/about/">About</a>
        <a href="/products/">Products</a>
        <a href="/csr/">CSR &amp; Sustainability</a>
        <a href="/blog/">Blog</a>
        <a href="/contact/">Contact</a>
      </div>

      <div class="footer-col">
        <div class="fcol-head">Products</div>
        {products.map((p) => (
          <a href={`/${p.slug}/`}>{p.shortName}</a>
        ))}
      </div>

      <div class="footer-col">
        <div class="fcol-head">Contact</div>
        <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a>
        <a href={waLink} target="_blank" rel="noopener">WhatsApp Chat</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span class="faddr">{site.address.full}</span>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} {site.legalName} ({site.brand}). All rights reserved.</span>
      <span class="ftrust">NABL Tested · High-Silica RHA · Export Ready</span>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--green-900); padding: 60px 0 30px; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .fmark {
    width: 40px; height: 40px; border-radius: 11px;
    background: var(--green-700);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold); font-family: var(--font-head); font-weight: 800; font-size: 19px;
  }
  .ftext { display: flex; flex-direction: column; line-height: 1; }
  .fname { font-family: var(--font-head); font-weight: 800; font-size: 17px; color: var(--cream); white-space: nowrap; }
  .fsub { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.18em; color: var(--gold); margin-top: 3px; }
  .fdesc { font-size: 14px; line-height: 1.6; color: #9fb09a; margin: 0 0 12px; max-width: 300px; }
  .fgst { font-family: var(--font-mono); font-size: 12px; color: #7e9078; letter-spacing: 0.04em; }

  .footer-col { display: flex; flex-direction: column; gap: 11px; }
  .fcol-head {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #7e9078;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .footer-col a, .faddr {
    font-size: 14px;
    color: #cbd6c7;
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.15s ease;
  }
  .footer-col a:hover { color: var(--gold); }

  .footer-bottom {
    padding-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer-bottom span { font-size: 13px; color: #7e9078; }
  .ftrust { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.06em; }

  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
