---
import { site } from '../config/site';
import { products } from '../data/products';
const year = new Date().getFullYear();
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand">
          <span class="fmark">
            <img src="/images/logo-mark.webp" alt="Ambika Biotech - RHA India logo" width="174" height="160" class="femblem" decoding="async" loading="lazy" />
          </span>
          <span class="ftext">
            <span class="fname">{site.name}</span>
            <span class="fsub">RHA INDIA</span>
          </span>
        </div>
        <p class="fdesc">
          Manufacturer &amp; exporter of high-silica Rice Husk Ash and rice husk
          products. {site.address.locality}, {site.address.region}, India.
        </p>
        <p class="fgst">GSTIN: {site.gstin}</p>
        <div class="fsocial">
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Ambika Biotech on Facebook">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h3v6h3v-6h2.6l.4-3H14V9.5c0-.3.2-.5.5-.5z"/></svg>
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Ambika Biotech on Instagram">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.86s0 3.6-.07 4.86c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.9.07s-3.6 0-4.86-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.6 2.2 15.2 2.2 12s0-3.6.07-4.86c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.21 8.8 2.2 12 2.2zm0 1.8c-3.15 0-3.5 0-4.74.07-.9.04-1.38.19-1.7.31-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.12.32-.27.8-.31 1.7C3.43 8.5 3.42 8.85 3.42 12s0 3.5.07 4.74c.04.9.19 1.38.31 1.7.17.43.37.74.69 1.06.32.32.63.52 1.06.69.32.12.8.27 1.7.31 1.24.07 1.59.07 4.74.07s3.5 0 4.74-.07c.9-.04 1.38-.19 1.7-.31.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.12-.32.27-.8.31-1.7.07-1.24.07-1.59.07-4.74s0-3.5-.07-4.74c-.04-.9-.19-1.38-.31-1.7a2.85 2.85 0 00-.69-1.06 2.85 2.85 0 00-1.06-.69c-.32-.12-.8-.27-1.7-.31C15.5 4 15.15 4 12 4zm0 3.06A4.94 4.94 0 1012 17a4.94 4.94 0 000-9.88zm0 8.15A3.2 3.2 0 1112 8.8a3.2 3.2 0 010 6.4zm6.3-8.35a1.15 1.15 0 11-2.3 0 1.15 1.15 0 012.3 0z"/></svg>
          </a>
          <a href={site.social.linkedin} target="_blank" rel="noopener" aria-label="Ambika Biotech on LinkedIn">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M6.94 5a1.94 1.94 0 11-3.88 0 1.94 1.94 0 013.88 0zM3.4 8.4h3.1V21H3.4V8.4zm5.06 0h2.97v1.72h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.74V21h-3.1v-5.6c0-1.34-.02-3.06-1.86-3.06-1.86 0-2.15 1.46-2.15 2.96V21h-3.1V8.4z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="Ambika Biotech on YouTube">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7c-.23-.83-.9-1.48-1.73-1.7C19.36 5.2 12 5.2 12 5.2s-7.36 0-8.87.4c-.83.22-1.5.87-1.73 1.7C1 8.8 1 12 1 12s0 3.2.4 4.7c.23.83.9 1.48 1.73 1.7 1.51.4 8.87.4 8.87.4s7.36 0 8.87-.4c.83-.22 1.5-.87 1.73-1.7.4-1.5.4-4.7.4-4.7zM9.75 15.02V8.98L15 12l-5.25 3.02z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <div class="fcol-head">Quick Links</div>
        <a href="/about/">About</a>
        <a href="/products/">Products</a>
        <a href="/csr/">CSR &amp; Sustainability</a>
        <a href="/blog/">Blog</a>
        <a href="/contact/">Contact</a>
      </div>

      <div class="footer-col">
        <div class="fcol-head">Products</div>
        {products.map((p) => (
          <a href={`/${p.slug}/`}>{p.shortName}</a>
        ))}
      </div>

      <div class="footer-col">
        <div class="fcol-head">Contact</div>
        <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a>
        <a href={waLink} target="_blank" rel="noopener">WhatsApp Chat</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span class="faddr">{site.address.full}</span>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} {site.legalName} ({site.brand}). All rights reserved.</span>
      <span class="ftrust">NABL Tested · High-Silica RHA · Export Ready</span>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--green-900); padding: 60px 0 30px; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .fmark {
    width: 44px; height: 44px; border-radius: 11px;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .femblem { width: 34px; height: auto; display: block; }
  .ftext { display: flex; flex-direction: column; line-height: 1; }
  .fname { font-family: var(--font-head); font-weight: 800; font-size: 17px; color: var(--cream); white-space: nowrap; }
  .fsub { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.18em; color: var(--gold); margin-top: 3px; }
  .fdesc { font-size: 15px; line-height: 1.6; color: #a9b9a4; margin: 0 0 12px; max-width: 300px; }
  .fgst { font-family: var(--font-mono); font-size: 13px; color: #8c9d86; letter-spacing: 0.04em; }

  .fsocial { display: flex; gap: 10px; margin-top: 16px; }
  .fsocial a {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #cbd6c7;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .fsocial a:hover { background: var(--gold); color: var(--green-900); transform: translateY(-2px); }

  .footer-col { display: flex; flex-direction: column; gap: 11px; }
  .fcol-head {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: #8c9d86;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .footer-col a, .faddr {
    font-size: 15px;
    color: #d2ddce;
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.15s ease;
  }
  .footer-col a:hover { color: var(--gold); }

  .footer-bottom {
    padding-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer-bottom span { font-size: 13.5px; color: #8c9d86; }
  .ftrust { font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.06em; }

  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
